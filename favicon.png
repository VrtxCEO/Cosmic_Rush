    <script>
    // Function to download favicon via proxy to avoid CORS issues
    function downloadFaviconProxy(url, domain, size) {
      // Create a temporary anchor element
      const a = document.createElement('a');
      a.href = url;
      
      // Set the download attribute with a filename based on domain and size
      const fileExtension = url.split('.').pop().split('?')[0] || 'ico';
      a.download = `${domain}-favicon-${size}.${fileExtension}`;
      
      // Trigger the download
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
    }
    
    // Function to copy favicon URL to clipboard
    function copyFaviconUrl(url) {
      navigator.clipboard.writeText(url).then(() => {
        // Show a temporary success message
        const toast = document.createElement('div');
        toast.className = 'fixed bottom-4 right-4 bg-green-500 text-white px-4 py-2 rounded-lg shadow-lg';
        toast.textContent = `${t('domainPage.urlCopied') || 'URL copied to clipboard!'}`;
        document.body.appendChild(toast);
        
        // Remove the toast after 2 seconds
        setTimeout(() => {
          toast.style.opacity = '0';
          toast.style.transition = 'opacity 0.5s';
          setTimeout(() => document.body.removeChild(toast), 500);
        }, 2000);
      }).catch(err => {
        console.error('Failed to copy URL: ', err);
        alert('Failed to copy URL to clipboard');
      });
    }

    // Function to copy color value to clipboard
    function copyColor(value) {
      navigator.clipboard.writeText(value).then(() => {
        const toast = document.createElement('div');
        toast.className = 'fixed bottom-4 right-4 bg-gray-900 text-white px-4 py-2 rounded-lg shadow-lg text-sm';
        toast.textContent = `${value} copied`;
        document.body.appendChild(toast);
        setTimeout(() => {
          toast.style.opacity = '0';
          toast.style.transition = 'opacity 0.5s';
          setTimeout(() => document.body.removeChild(toast), 500);
        }, 1600);
      }).catch(err => {
        console.error('Failed to copy color: ', err);
        alert('Failed to copy color');
      });
    }
    </script>
